bind j everywhere down
bind k everywhere up
bind m articlelist toggle-article-read
bind m feedlist toggle-article-read
browser "xdg-open %u"

# Higher-contrast palette for dark terminals.
color background          default default
color listnormal          color250 default
color listnormal_unread   color223 default bold
color listfocus           color230 color237 bold
color listfocus_unread    color230 color237 bold
color title               color223 color239 bold
color info                color246 color237
color hint-key            color214 color237 bold
color hint-keys-delimiter color241 color237
color hint-separator      color214 color237 bold
color hint-description    color246 color237
color article             color250 default
color end-of-text-marker  color239 default
