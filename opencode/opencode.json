{
  "$schema": "https://opencode.ai/config.json",
  "autoupdate": true,
  "permission": {
    "bash": {
      "*": "allow",
      "git commit *": "ask",
      "git push": "ask",
      "git push *": "ask",
      "git push --force *": "ask",
      "git rebase *": "ask",
      "git reset --hard *": "ask"
    },
    "read": {
      "*": "allow",
      "**/.env": "deny",
      "**/.env.*": "deny",
      "**/credentials.json": "deny",
      "**/secrets/**": "deny",
      "*.env": "deny",
      "*.env.*": "deny"
    }
  },
  "agent": {
    "architect": {
      "permission": {
        "task": {
          "*": "allow"
        }
      }
    },
    "implementor": {
      "permission": {
        "task": {
          "*": "deny"
        }
      }
    },
    "tester": {
      "permission": {
        "task": {
          "*": "deny"
        }
      }
    },
    "reviewer": {
      "permission": {
        "task": {
          "*": "deny"
        }
      }
    },
    "debugger": {
      "permission": {
        "task": {
          "*": "deny"
        }
      }
    },
    "docs-writer": {
      "permission": {
        "task": {
          "*": "deny"
        }
      }
    },
    "refactorer": {
      "permission": {
        "task": {
          "*": "deny"
        }
      }
    },
    "git-ops": {
      "permission": {
        "task": {
          "*": "deny"
        }
      }
    }
  },
  "mcp": {
    "context7": {
      "enabled": true,
      "type": "remote",
      "url": "https://mcp.context7.com/mcp"
    }
  }
}
