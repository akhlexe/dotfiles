{
    "$schema": "https://opencode.ai/config.json",
    "model": "openai/gpt-5.4",
    "agent": {
        "architect": {
            "model": "openai/gpt-5.4",
            "permission": {
                "task": {
                    "*": "allow"
                }
            }
        },
        "explorer": {
            "model": "openai/gpt-5.3-codex",
            "permission": {
                "task": {
                    "*": "deny"
                }
            }
        },
        "atomic-executor": {
            "model": "openai/gpt-5.3-codex",
            "permission": {
                "task": {
                    "*": "deny"
                }
            }
        },
        "implementor": {
            "model": "openai/gpt-5.3-codex",
            "permission": {
                "task": {
                    "*": "deny"
                }
            }
        },
        "tester": {
            "model": "openai/gpt-5.3-codex",
            "permission": {
                "task": {
                    "*": "deny"
                }
            }
        },
        "reviewer": {
            "model": "openai/gpt-5.3-codex",
            "permission": {
                "task": {
                    "*": "deny"
                }
            }
        },
        "debugger": {
            "model": "openai/gpt-5.3-codex",
            "permission": {
                "task": {
                    "*": "deny"
                }
            }
        },
        "docs-writer": {
            "model": "openai/gpt-5.3-codex",
            "permission": {
                "task": {
                    "*": "deny"
                }
            }
        },
        "refactorer": {
            "model": "openai/gpt-5.3-codex",
            "permission": {
                "task": {
                    "*": "deny"
                }
            }
        },
        "git-ops": {
            "model": "openai/gpt-5.3-codex",
            "permission": {
                "task": {
                    "*": "deny"
                }
            }
        }
    },
    "default_agent": "plan",
    "autoupdate": true,
    "mcp": {
        "context7": {
            "enabled": true,
            "type": "remote",
            "url": "https://mcp.context7.com/mcp"
        },
        "engram": {
            "command": [
                "/home/exequiel/go/bin/engram",
                "mcp",
                "--tools=agent"
            ],
            "enabled": true,
            "type": "local"
        }
    },
    "permission": {
        "bash": {
            "*": "allow",
            "git commit *": "ask",
            "git push": "ask",
            "git push *": "ask",
            "git push --force *": "ask",
            "git rebase *": "ask",
            "git reset --hard *": "ask"
        },
        "read": {
            "*": "allow",
            "**/.env": "deny",
            "**/.env.*": "deny",
            "**/credentials.json": "deny",
            "**/secrets/**": "deny",
            "*.env": "deny",
            "*.env.*": "deny"
        }
    }
}
